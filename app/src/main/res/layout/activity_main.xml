<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Full-screen video -->
    <SurfaceView
        android:id="@+id/surface_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top HUD (semi-transparent) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_gravity="top"
        android:background="#55000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/tvConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○"
            android:textColor="#E74C3C"
            android:textSize="14sp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/textview_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/HudText"
            android:text="NOT CONNECTED" />

        <Button
            android:id="@+id/btnSpeed"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="SPD: MED"
            android:textSize="10sp"
            android:textColor="@color/textAccent"
            android:background="#44000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnVideo"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="@string/start_video"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#44000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- Bottom controls (transparent overlay) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#33000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Left joystick (clean, no D-pad) -->
        <com.duvitech.tello.JoystickView
            android:id="@+id/joystickLeft"
            android:layout_width="160dp"
            android:layout_height="160dp" />

        <!-- Center controls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Flight buttons row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnTakeoff"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:text="TAKEOFF"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:background="#BB2ECC71"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnLand"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:text="LAND"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:background="#BBF39C12"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnEmergency"
                    android:layout_width="60dp"
                    android:layout_height="44dp"
                    android:text="STOP"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:background="#BBE74C3C" />
            </LinearLayout>

            <!-- Function buttons 2x2 grid -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">

                    <Button
                        android:id="@+id/btnPhoto"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:text="📷 PHOTO"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"
                        android:background="#5500D4FF"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnRecord"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:text="⏺ REC"
                        android:textSize="10sp"
                        android:textColor="#E74C3C"
                        android:background="#44000000" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnSpeedUp"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:text="SPD ▲"
                        android:textSize="10sp"
                        android:textColor="@color/textAccent"
                        android:background="#44000000"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnSpeedDown"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:text="SPD ▼"
                        android:textSize="10sp"
                        android:textColor="@color/textAccent"
                        android:background="#44000000" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Right joystick (clean) -->
        <com.duvitech.tello.JoystickView
            android:id="@+id/joystickRight"
            android:layout_width="160dp"
            android:layout_height="160dp" />

    </LinearLayout>

</FrameLayout>
