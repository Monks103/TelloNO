<resources>
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="HudText">
        <item name="android:textColor">@color/textHud</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="FlightButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <style name="FlipButton">
        <item name="android:textColor">@color/textAccent</item>
        <item name="android:textSize">18sp</item>
        <item name="android:background">@color/btnFlip</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:minWidth">44dp</item>
        <item name="android:minHeight">44dp</item>
    </style>
</resources>
